{
  "name": "nosaj_raw",
  "version": "1.0.0",
  "author": "Jason Howmans <jason@nosaj.io>",
  "license": "MIT",
  "main": "dist/server/index.js",
  "targets": {
    "default": {
      "distDir": "dist"
    },
    "client": {
      "source": "src/client/index.html",
      "engines": {
        "browsers": "> 0.5%, last 2 versions, not dead"
      }
    },
    "server": {
      "engines": {
        "node": ">= 12"
      },
      "source": "src/server/index.ts"
    }
  },
  "@parcel/transformer-css": {
    "drafts": {
      "nesting": true
    }
  },
  "scripts": {
    "build": "parcel build",
    "start": "node dist/server/index.js",
    "watch": "nodemon --watch src -e ts,css,html --exec 'yarn build && yarn start'"
  },
  "dependencies": {
    "@parcel/core": "^2.6.0",
    "@swc/helpers": "^0.3.17",
    "fastify": "^3.29.0",
    "normalize.css": "^8.0.1",
    "regenerator-runtime": "^0.13.9"
  },
  "devDependencies": {
    "@types/node": "^17.0.38",
    "assert": "^2.0.0",
    "buffer": "^6.0.3",
    "events": "^3.3.0",
    "https-browserify": "^1.0.0",
    "nodemon": "^2.0.16",
    "parcel": "^2.6.0",
    "postcss": "^8.4",
    "postcss-custom-properties": "^12.1.7",
    "postcss-import": "^14.1.0",
    "postcss-url": "^10.1.3",
    "process": "^0.11.10",
    "querystring-es3": "^0.2.1",
    "stream-browserify": "^3.0.0",
    "stream-http": "^3.2.0",
    "url": "^0.11.0",
    "util": "^0.12.4"
  }
}
