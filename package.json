{
  "name": "nosaj_raw",
  "version": "1.0.0",
  "author": "Jason Howmans <jason@nosaj.io>",
  "license": "MIT",
  "main": "dist/server/index.js",
  "targets": {
    "default": {
      "distDir": "dist"
    },
    "client": {
      "source": "src/client/index.html",
      "engines": {
        "browsers": "> 0.5%, last 2 versions, not dead"
      }
    },
    "server": {
      "engines": {
        "node": ">= 12"
      },
      "source": "src/server/index.ts"
    }
  },
  "@parcel/transformer-css": {
    "drafts": {
      "nesting": true
    }
  },
  "scripts": {
    "build": "parcel build",
    "start": "node dist/server/index.js",
    "watch": "nodemon --watch src -e ts,css,html --exec 'yarn build && yarn start'"
  },
  "dependencies": {
    "fastify": "^3.29.0",
    "normalize.css": "^8.0.1"
  },
  "devDependencies": {
    "@types/node": "^17.0.38",
    "nodemon": "^2.0.16",
    "parcel": "^2.6.0",
    "postcss": "^8.0.0",
    "postcss-custom-properties": "^12.1.7",
    "postcss-import": "^14.1.0",
    "postcss-url": "^10.1.3"
  }
}
