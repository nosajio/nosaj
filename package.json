{
  "name": "nosaj_raw",
  "version": "1.0.0",
  "author": "Jason Howmans <jason@nosaj.io>",
  "license": "MIT",
  "main": "dist/index.js",
  "targets": {
    "server": {
      "engines": {
        "node": ">= 12"
      },
      "distDir": "dist",
      "source": "src/server/index.ts"
    },
    "client": {
      "source": "src/css/index.css",
      "engines": {
        "browsers": "> 0.5%, last 2 versions, not dead"
      }
    }
  },
  "@parcel/transformer-css": {
    "drafts": {
      "nesting": true
    }
  },
  "scripts": {
    "build": "node scripts/build",
    "start": "node dist/index.js",
    "watch": ""
  },
  "dependencies": {
    "esbuild-sass-plugin": "^2.2.6",
    "express": "^4.18.1",
    "hyperscript": "^2.0.2",
    "normalize.css": "^8.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.13",
    "@types/hyperscript": "^0.0.4",
    "@types/node": "^17.0.38",
    "@types/react": "^18.0.10",
    "esbuild": "^0.14.42"
  }
}
