{
  "jsc": {
    "parser": {
      "syntax": "typescript",
      "tsx": true,
      "decorators": false,
      "dynamicImport": true
    },
    "transform": {
      "react": {
        "pragma": "h",
        "pragmaFrag": "Fragment"
      }
    }
  },
  "env": {
    "targets": {
      "node": "16"
    }
  }
}
