<%- include('includes/header') -%>
<main>
  <%- include('includes/navbar') -%>
    <div class="reading-bg post-outer">
      <% if (cover) { %>
        <div class="post-cover" style="background-image: url('<%= cover %>')"></div>
      <% } %>
      <article class="content-surface container post">
        <header class="post-header">
          <h1 class="post-title">
            <%= title %>
          </h1>
          <div class="post-date">
            <%= nice_date %> 
          </div>
        </header>
        <section class="post-body">
          <%- html %>
        </section>
      </article>
    </div>
</main>
<%- include('includes/footer') -%>